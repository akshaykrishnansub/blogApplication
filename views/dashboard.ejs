<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <title>Blog | Dashboard</title>
    <style>
        aside a{
            color: white;
        }
        aside a:hover{
            color:#60A5FA;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark navbar-expand-lg p-3 sticky-top" style="background-color: #2563EB;;">
        <div class="container-fluid">
            <a href="/" class="navbar-brand fw-bold">Blogifier</a>
            <form action="/auth/logout" method="POST">
                <button type="submit" class="btn btn-info">Logout</button>
            </form>
        </div>
    </nav>
    <div class="container-fluid">
        <div class="row">
            <aside style="background-color: black; color: white; height: 100vh; width:220px;top:56px;">
                <h5 class="p-3">Menu</h5>
                <div class="mt-4"><a href="/blogs/compose" style="text-decoration: none;">Create a Blog</a></div>
                <div class="mt-4"><a href="/blogs/myblogs" class="mt-4" style="text-decoration: none;">My Blogs</a></div>
                <div class="mt-4"><a href="" style="text-decoration: none;">All Blogs Database</a></div>
            </aside>
            <main class="col-md-10 mt-4">
                <h2>Dashboard</h2>
                <div class="row mt-4">
                    <div class="col-md-3">
                        <div class="card shadow">
                            <div class="card-body">
                                <h5>Total Blogs Published:</h5>
                                <h3>120</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow">
                            <div class="card-body">
                                <h5> My Total Blogs Published:</h5>
                                <h3>70</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow">
                            <div class="card-body">
                                <h5>Number of users:</h5>
                                <h3>8</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
        
</body>
</html>