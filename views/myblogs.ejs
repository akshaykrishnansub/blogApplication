<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <title>MyBlogs</title>
</head>
<body>
    <nav class="navbar navbar-dark navbar-expand-lg p-3 sticky-top" style="background-color: #2563EB;">
        <div class="container-fluid">
            <a href="/" class="navbar-brand fw-bold" style="text-decoration: none;">Blogifier</a>
            <form action="/auth/logout" method="POST">
                <button type="submit" class="btn btn-info">Logout</button>
            </form>
        </div>
    </nav>
    <div class="mt-4 text-center">
        <h5 class="fw-bold" style="font-size: 30px;">MY BLOGS</h5>
        <%blogs.forEach(blog=>{%>
        <div class="container mt-4">
            <div style="background-color:darkblue" class="rounded-1 p-3">     
                <div><span style="font-size: 25px; color:white;font-weight: bold;">Title: </span><span style="font-size: 20px;color:white"><%=blog.title %></span></div>
                <div><span style="font-size: 25px; color:white;font-weight: bold;">Category: </span><span style="font-size: 20px;color:white"><%=blog.category %></span></div>
                <div><span style="font-size: 25px; color:white;font-weight: bold;">Author: </span><span style="font-size: 20px;color:white"><%=blog.author %></span></div>
                <div><span style="font-size: 25px; color:white;font-weight: bold;">Blog Date: </span><span style="font-size: 20px;color:white"><%=new Date(blog.blog_date).toLocaleString() %></span></div>
                <div><span style="font-size: 25px; color:white;font-weight: bold;">Body: </span><span style="font-size: 20px;color:white"><%=blog.body.substring(0,120) %>...<a href="/blog/<%=blog.id %>" style="color:white">Read More</a></span></div>
            </div>            
        </div>
        <%})%>
    </div>
</body>
</html>