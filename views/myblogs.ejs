<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <title>MyBlogs</title>
</head>
<body>
    <nav class="navbar navbar-dark navbar-expand-lg p-3 sticky-top" style="background-color: #2563EB;">
        <div class="container-fluid">
            <a href="/" class="navbar-brand fw-bold" style="text-decoration: none;">Blogifier</a>
            <form action="/auth/logout" method="POST">
                <button type="submit" class="btn btn-info">Logout</button>
            </form>
        </div>
    </nav>
    <div class="mt-4 text-center mb-4">
        <h5 class="fw-bold" style="font-size: 30px;">MY BLOGS</h5>
        <div class="container mt-3">
            <form action="/blogs/search" method="GET" class="d-flex justify-content-center">
                <input type="text"
                name="q"
                placeholder="Search by title,category or author"
                class="form-control w-50 me-2"
                >
                <button class="btn btn-primary">Search</button>
            </form>
        </div>
        <% if(blogs.length===0){%>
            <h2>No blogs found</h2>
            <%}else{%>
        <%blogs.forEach(blog=>{%>
        <div class="container mt-4">
            <div style="background-color:darkblue" class="rounded-1 p-3">     
                <div class="mt-4"><span style="font-size: 25px; color:white;font-weight: bold;">Title: </span><span style="font-size: 20px;color:white"><%=blog.title %></span></div>
                <div class="mt-4"><span style="font-size: 25px; color:white;font-weight: bold;">Category: </span><span style="font-size: 20px;color:white"><%=blog.category %></span></div>
                <div class="mt-4"><span style="font-size: 25px; color:white;font-weight: bold;">Author: </span><span style="font-size: 20px;color:white"><%=blog.author %></span></div>
                <div class="mt-4"><span style="font-size: 25px; color:white;font-weight: bold;">Blog Date: </span><span style="font-size: 20px;color:white"><%=new Date(blog.blog_date).toLocaleString() %></span></div>
                <div class="mt-4"><span style="font-size: 25px; color:white;font-weight: bold;">Body: </span><span style="font-size: 20px;color:white"><%=blog.body.substring(0,120) %>...<a href="/blog/<%=blog.id %>" style="color:white">Read More</a></span></div>
                <div class="mt-4 mb-4">
                    <form action="/blog/edit/<%= blog.id %>" method="GET" style="display: inline;">
                        <button class="p-2 rounded" style="background-color: darkgreen;color:white;">Edit Blog</button>
                    </form>
                    <form action="/blogs/delete/<%= blog.id %>" method="POST" style="display: inline;">
                        <button class="p-2 rounded" style="background-color: red;color:white; display: inline;" onclick="return confirm('Are you sure you want to delete this blog?')">Delete Blog</button>
                    </form>
                </div>
            </div>            
        </div>
        <%})%>
        <% } %>
        <div class="mt-4">
            <a href="/blogs/dashboard" style="color:black">Go Back to Dashboard</a>
        </div>
    </div>
</body>
</html>