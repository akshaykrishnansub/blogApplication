<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%=blog.title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

</head>
<body>
    <nav class="navbar navbar-dark navbar-expand-lg p-3 sticky-top" style="background-color: #2563EB;">
        <div class="container-fluid">
            <a href="/" class="navbar-brand fw-bold">Blogifier</a>
            <form action="/auth/logout" method="POST">
                <button type="submit" class="btn btn-info">Logout</button>
            </form>
        </div>
    </nav>
    <div class="p-3">
        <h1><%= blog.title %></h1>
        <div class="mt-4"><p><span class="fw-bold" style="font-size: 20px;">Category: </span><span style="font-size: 19px;"><%= blog.category%></span></p></div>
        <div class="mt-4"><p><span class="fw-bold" style="font-size: 20px;">Author: </span><span style="font-size: 19px;"><%= blog.author %></span></p></div>        <div class="mt-4"><p><span class="fw-bold" style="font-size: 20px;">Blog Date: </span><span style="font-size: 19px;"><%= new Date(blog.blog_date).toLocaleString() %></span></p></div>
        <div class="mt-4"><p><span class="fw-bold" style="font-size: 20px;">Body: </span><span style="font-size: 19px;"><%= blog.body %></span></p></div>
    </div>
</body>
</html>